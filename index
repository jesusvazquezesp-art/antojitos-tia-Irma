<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Puesto de Cecy</title>

<style>
body{
    margin:0;
    font-family: Arial, sans-serif;
    background:#fff3e0;
    color:#3e2723;
}
header{
    background:#d84315;
    color:white;
    text-align:center;
    padding:25px 10px;
}
header h1{
    margin:0;
    font-size:32px;
}
header p{
    margin:8px 0 0;
    font-size:17px;
}
.contenedor{
    max-width:1100px;
    margin:auto;
    padding:20px;
}
.productos{
    display:grid;
    grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));
    gap:20px;
}
.card{
    background:white;
    border-radius:18px;
    overflow:hidden;
    box-shadow:0 4px 12px rgba(0,0,0,.18);
    text-align:center;
}
.card img{
    width:100%;
    height:180px;
    object-fit:cover;
}
.card h3{
    margin:15px 10px 5px;
    color:#bf360c;
}
.precio{
    font-size:22px;
    font-weight:bold;
    color:#2e7d32;
    margin:10px;
}
.btn{
    display:block;
    margin:15px;
    padding:12px;
    background:#25D366;
    color:white;
    text-decoration:none;
    border-radius:12px;
    font-weight:bold;
}
.btn:hover{
    background:#128C7E;
}
footer{
    text-align:center;
    padding:20px;
    background:#3e2723;
    color:white;
    margin-top:30px;
}
</style>
</head>

<body>

<header>
    <h1>🌮 Puesto de Cecy</h1>
    <p>Pedidos rápidos por WhatsApp</p>
</header>

<div class="contenedor">

    <div class="productos">

        <div class="card">
            <img src="fotos/tacos.jpg" alt="Tacos">
            <h3>Tacos</h3>
            <p class="precio">$25</p>
            <a class="btn" href="https://wa.me/526566676177?text=Hola%20Cecy,%20quiero%20pedir%20tacos" target="_blank">
                Pedir por WhatsApp
            </a>
        </div>

        <div class="card">
            <img src="fotos/burritos.jpg" alt="Burritos">
            <h3>Burritos</h3>
            <p class="precio">$35</p>
            <a class="btn" href="https://wa.me/526566676177?text=Hola%20Cecy,%20quiero%20pedir%20burritos" target="_blank">
                Pedir por WhatsApp
            </a>
        </div>

        <div class="card">
            <img src="fotos/tortas.jpg" alt="Tortas">
            <h3>Tortas</h3>
            <p class="precio">$50</p>
            <a class="btn" href="https://wa.me/526566676177?text=Hola%20Cecy,%20quiero%20pedir%20tortas" target="_blank">
                Pedir por WhatsApp
            </a>
        </div>

        <div class="card">
            <img src="fotos/agua.jpg" alt="Agua fresca">
            <h3>Agua fresca</h3>
            <p class="precio">$20</p>
            <a class="btn" href="https://wa.me/526566676177?text=Hola%20Cecy,%20quiero%20pedir%20agua%20fresca" target="_blank">
                Pedir por WhatsApp
            </a>
        </div>

    </div>

</div>

<footer>
    © 2026 Puesto de Cecy · Gracias por tu compra
</footer>

</body>
</html>